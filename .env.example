# =============================================================================
# Urbane Calendar — Environment Variables
# =============================================================================
#
# TWO-FILE STRATEGY (no manual editing to switch environments):
#
#   .env.local              — Production Supabase values (gitignored)
#   .env.development.local  — Local Docker Supabase values (gitignored)
#                             Highest priority in dev mode. Auto-overrides
#                             .env.local when running `npm run dev`.
#
#   Run `/switch-env local` to create .env.development.local automatically.
#   Run `/switch-env production` to delete it and fall back to .env.local.
#
#   See .claude/skills/switch-env/SKILL.md for details.
#
# Copy this file to .env.local and fill in your production values.
# For local dev values, use the switch-env skill — don't copy them here.
# =============================================================================

# ---- Supabase ----
# LOCAL:  http://127.0.0.1:54321
# REMOTE: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# LOCAL:  Printed by `supabase start` (starts with eyJ...)
# REMOTE: Found in Supabase Dashboard > Settings > API > anon/public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=

# LOCAL:  Printed by `supabase start` (starts with eyJ...)
# REMOTE: Found in Supabase Dashboard > Settings > API > service_role
# WARNING: Never expose this to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Email (Resend) ----
# Used for sending invitation emails. Not needed for local dev —
# the local Inbucket captures all emails at http://127.0.0.1:54324
RESEND_API_KEY=
